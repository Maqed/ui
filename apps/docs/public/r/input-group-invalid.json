{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "input-group-invalid",
  "registryDependencies": [
    "https://herocn.dev/r/field.json",
    "https://herocn.dev/r/input-group.json"
  ],
  "files": [
    {
      "path": "components/examples/input-group-invalid.tsx",
      "content": "import { SearchIcon } from \"lucide-react\";\n\nimport { Field, FieldError, FieldLabel } from \"@/components/ui/field\";\nimport {\n  InputGroup,\n  InputGroupAddon,\n  InputGroupInput,\n  InputGroupTextarea,\n} from \"@/components/ui/input-group\";\n\nexport default function InputGroupInvalid() {\n  return (\n    <div className=\"grid w-full max-w-sm gap-6\">\n      <Field data-invalid>\n        <FieldLabel htmlFor=\"invalid-input\">Search</FieldLabel>\n        <InputGroup>\n          <InputGroupInput\n            id=\"invalid-input\"\n            aria-invalid\n            placeholder=\"Search...\"\n          />\n          <InputGroupAddon>\n            <SearchIcon />\n          </InputGroupAddon>\n        </InputGroup>\n        <FieldError>Please enter a valid search term.</FieldError>\n      </Field>\n      <Field data-invalid>\n        <FieldLabel htmlFor=\"invalid-textarea\">Message</FieldLabel>\n        <InputGroup>\n          <InputGroupTextarea\n            id=\"invalid-textarea\"\n            aria-invalid\n            placeholder=\"Enter your message...\"\n          />\n        </InputGroup>\n        <FieldError>Message cannot be empty.</FieldError>\n      </Field>\n    </div>\n  );\n}\n",
      "type": "registry:example"
    }
  ],
  "type": "registry:example"
}