{
	"name": "herocn",
	"version": "0.0.0",
	"private": true,
	"scripts": {
		"check": "biome check --write .",
		"prepare": "husky || true",
		"build": "next build",
		"dev": "next dev --port=4000",
		"start": "serve out",
		"deps": "bunx taze@latest -Ilw",
		"types:check": "fumadocs-mdx && next typegen && tsc --noEmit",
		"postinstall": "fumadocs-mdx",
		"lint": "biome check",
		"format": "biome format --write",
		"registry:build": "bun ./src/scripts/build-registry.mts"
	},
	"dependencies": {
		"@base-ui/react": "^1.4.1",
		"@orama/orama": "^3.1.18",
		"@takumi-rs/image-response": "^1.1.2",
		"chrono-node": "^2.9.1",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"cmdk": "^1.1.1",
		"date-fns": "^4.1.0",
		"fumadocs-core": "16.8.11",
		"fumadocs-mdx": "15.0.5",
		"fumadocs-ui": "npm:@fumadocs/base-ui@16.8.11",
		"jotai": "^2.20.0",
		"lucide-react": "^1.16.0",
		"next": "^16.2.6",
		"next-themes": "^0.4.6",
		"react": "^19.2.6",
		"react-day-picker": "^10.0.1",
		"react-dom": "^19.2.6",
		"rimraf": "^6.1.3",
		"shadcn": "^4.7.0",
		"sonner": "^2.0.7",
		"tailwind-merge": "^3.6.0",
		"ts-morph": "^28.0.0",
		"tw-animate-css": "^1.4.0",
		"vaul": "^1.1.2"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.15",
		"@tailwindcss/postcss": "^4.3.0",
		"@types/mdx": "^2.0.13",
		"@types/node": "^25.8.0",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"husky": "^9.1.7",
		"lint-staged": "^17.0.5",
		"postcss": "^8.5.14",
		"serve": "^14.2.6",
		"tailwindcss": "^4.3.0",
		"typescript": "^6.0.3"
	},
	"lint-staged": {
		"*.{js,ts,cjs,mjs,d.cts,d.mts,jsx,tsx,json,jsonc}": [
			"biome check --write ."
		]
	},
	"packageManager": "bun@1.3.14"
}
