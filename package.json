{
	"name": "herocn",
	"version": "0.0.0",
	"private": true,
	"scripts": {
		"check": "biome check --write .",
		"prepare": "husky || true",
		"build": "next build",
		"dev": "next dev --port=4000",
		"start": "serve out",
		"types:check": "fumadocs-mdx && next typegen && tsc --noEmit",
		"postinstall": "fumadocs-mdx",
		"lint": "biome check",
		"format": "biome format --write",
		"registry:build": "bun ./src/scripts/build-registry.mts"
	},
	"dependencies": {
		"@base-ui/react": "^1.4.0",
		"@orama/orama": "^3.1.18",
		"@takumi-rs/image-response": "^0.70.4",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"fumadocs-core": "16.6.16",
		"fumadocs-mdx": "14.2.9",
		"fumadocs-ui": "npm:@fumadocs/base-ui@16.6.16",
		"jotai": "^2.18.1",
		"lucide-react": "^0.577.0",
		"next": "^16.2.4",
		"next-themes": "^0.4.6",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"rimraf": "^6.1.3",
		"shadcn": "^4.0.8",
		"sonner": "^2.0.7",
		"tailwind-merge": "^3.5.0",
		"ts-morph": "^27.0.2",
		"tw-animate-css": "^1.4.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.6",
		"@tailwindcss/postcss": "^4.2.1",
		"@types/mdx": "^2.0.13",
		"@types/node": "^25.3.5",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"postcss": "^8.5.8",
		"serve": "^14.2.6",
		"tailwindcss": "^4.2.1",
		"typescript": "^5.9.3",
		"husky": "^9.1.7",
		"lint-staged": "^16.1.2"
	},
	"lint-staged": {
		"*.{js,ts,cjs,mjs,d.cts,d.mts,jsx,tsx,json,jsonc}": [
			"biome check --write ."
		]
	},
	"packageManager": "bun@1.3.6"
}
